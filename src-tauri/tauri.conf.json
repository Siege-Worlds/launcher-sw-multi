{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Siege Worlds Launcher",
  "version": "0.1.0",
  "identifier": "io.siegeworlds.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx serve dist -l 1420 --no-clipboard",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Siege Worlds Launcher",
        "width": 960,
        "height": 568,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http: https:"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {}
  }
}
